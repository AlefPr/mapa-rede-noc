# Configurações do Servidor Node.js
PORT=3000

# URL do Frontend (para CORS). IPs da máquina são detetados automaticamente.
FRONTEND_URL=http://localhost
# Origins adicionais permitidas (separadas por vírgula)
# FRONTEND_URLS=http://outro-dominio.local

# Credenciais do Banco de Dados MySQL
DB_HOST=localhost
DB_USER=mapa_user
DB_PASS=
DB_NAME=mapa_rotas
DB_CONNECTION_LIMIT=10

# Integração Zabbix 7.0.21
ZABBIX_API_URL=http://127.0.0.1/zabbix/api_jsonrpc.php
ZABBIX_API_TOKEN=insira_aqui_o_token_gerado_na_interface_do_zabbix

# Webhook Secret (para autenticação do webhook do Zabbix)
WEBHOOK_SECRET=insira_um_segredo_aqui

# Configuração do Motor de Cache Zabbix
ZABBIX_POLLING_INTERVAL=30000
ZABBIX_REQUEST_TIMEOUT=15000
CACHE_HISTORY_LIMIT=120

# Logging
LOG_LEVEL=info

# Autenticação JWT
JWT_SECRET=altere_esta_chave_para_um_valor_seguro
JWT_EXPIRES_IN=24h

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100